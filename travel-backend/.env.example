# =========================================
# 🔧 BACKEND ENVIRONMENT CONFIGURATION
# =========================================

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/travel_db

# API Configuration
PORT=3001
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters

# Mapbox API (Required for places search and routing)
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token-here

# Optional: Frontend URL for CORS (if you need to restrict it)
# FRONTEND_URL=http://localhost:3000

